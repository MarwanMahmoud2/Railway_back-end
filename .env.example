APP_NAME="NBIS Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------
# Database — Supabase PostgreSQL
# -----------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

VITE_USE_DEV_SERVER=false
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------
# Admin/Nurse/Police seeder credentials
# -----------------------------------------------------------------------
ADMIN_EMAIL=admin@nbis.com
ADMIN_NAME="System Admin"
ADMIN_PHONE=+201000000001
ADMIN_PASSWORD=Admin@1234

NURSE_EMAIL=nurse@nbis.com
NURSE_NAME="Nurse Sarah"
NURSE_PHONE=+201000000002
NURSE_PASSWORD=Nurse@1234

POLICE_EMAIL=police@nbis.com
POLICE_NAME="Officer Ahmed"
POLICE_PHONE=+201000000003
POLICE_PASSWORD=Police@1234

# -----------------------------------------------------------------------
# Footprint AI (FastAPI)
# -----------------------------------------------------------------------
FOOTPRINT_AI_URL=https://your-ai-service-url.com

# -----------------------------------------------------------------------
# Sanctum / Session / CORS
# -----------------------------------------------------------------------
SANCTUM_EXPIRATION=4320
SANCTUM_STATEFUL_DOMAINS=your-app.up.railway.app,your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,*
CORS_SUPPORTS_CREDENTIALS=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

# -----------------------------------------------------------------------
# Supabase Storage
# -----------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
